{
  "name": "nito-wallet-mobile",
  "version": "1.1.3",
  "private": true,
  "main": "node_modules/expo/AppEntry.js",
  "type": "module",
  "expo": {
    "autolinking": {
      "ios": {
        "buildFromSource": [
          "expo-modules-core"
        ]
      },
      "android": {
        "buildFromSource": [
          "expo-file-system"
        ]
      }
    }
  },
  "scripts": {
    "postinstall": "patch-package --error-on-fail",
    "eas-build-pre-install": "node scripts/ensure-rust-toolchains.mjs",
    "rust:fmt": "cargo fmt --manifest-path native/nito-wallet-crypto/Cargo.toml --check",
    "rust:clippy": "cargo clippy --manifest-path native/nito-wallet-crypto/Cargo.toml --all-targets --locked -- -D warnings",
    "rust:test": "cargo test --manifest-path native/nito-wallet-crypto/Cargo.toml --lib --locked",
    "doctor": "expo-doctor",
    "warnings:self-test": "node scripts/assert-warning-free.mjs --self-test",
    "warnings:source": "node scripts/assert-no-warning-suppressions.mjs",
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "ios:free:prebuild": "node scripts/prebuild-ios-free.mjs",
    "web": "expo start --web",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --max-warnings=0",
    "test": "vitest run",
    "test:watch": "vitest",
    "eas:login": "npx eas-cli@20.2.0 login",
    "eas:init": "npx eas-cli@20.2.0 init",
    "build:apk": "npx eas-cli@20.2.0 build --platform android --profile preview",
    "build:ipa": "npx eas-cli@20.2.0 build --platform ios --profile production",
    "build:android:preview": "npx eas-cli@20.2.0 build --platform android --profile preview",
    "build:ios:preview": "npx eas-cli@20.2.0 build --platform ios --profile preview",
    "build:android:store": "npx eas-cli@20.2.0 build --platform android --profile production",
    "build:ios:store": "npx eas-cli@20.2.0 build --platform ios --profile production",
    "build:all:store": "npx eas-cli@20.2.0 build --platform all --profile production",
    "submit:android": "npx eas-cli@20.2.0 submit --platform android --profile production --latest",
    "submit:ios": "npx eas-cli@20.2.0 submit --platform ios --profile production --latest"
  },
  "dependencies": {
    "@noble/hashes": "2.2.0",
    "@noble/secp256k1": "^2.2.0",
    "@scure/bip32": "2.2.0",
    "@scure/bip39": "2.2.0",
    "@scure/btc-signer": "^2.2.0",
    "bech32": "^2.0.0",
    "expo": "~57.0.7",
    "expo-asset": "~57.0.6",
    "expo-camera": "~57.0.2",
    "expo-clipboard": "~57.0.1",
    "expo-constants": "~57.0.6",
    "expo-file-system": "~57.0.1",
    "expo-local-authentication": "~57.0.1",
    "expo-secure-store": "~57.0.1",
    "expo-sharing": "~57.0.6",
    "expo-splash-screen": "~57.0.4",
    "expo-sqlite": "~57.0.1",
    "expo-system-ui": "~57.0.1",
    "react": "19.2.3",
    "react-native": "0.86.0",
    "react-native-get-random-values": "~1.11.0",
    "react-native-qrcode-svg": "file:vendor/react-native-qrcode-svg",
    "react-native-safe-area-context": "~5.7.0",
    "tweetnacl": "^1.0.3"
  },
  "devDependencies": {
    "@types/react": "~19.2.14",
    "babel-preset-expo": "^57.0.3",
    "eslint": "9.39.5",
    "eslint-config-expo": "~57.0.0",
    "eslint-import-resolver-typescript": "4.4.5",
    "expo-doctor": "1.20.1",
    "globals": "^16.0.0",
    "patch-package": "^8.0.1",
    "typescript": "~7.0.2",
    "vitest": "^4.1.10"
  },
  "overrides": {
    "eslint-import-resolver-typescript": "4.4.5",
    "uuid": "^11.1.1"
  }
}
